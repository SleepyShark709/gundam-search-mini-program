<view class="page">
  <!-- Header -->
  <header title="GUNDAM SEARCH" showBack="{{false}}" />

  <!-- Main content -->
  <view class="content">
    <view class="main" wx:if="{{!loading && series.length > 0}}">
      <swiper
        class="carousel"
        current="{{activeIndex}}"
        previous-margin="85rpx"
        next-margin="85rpx"
        circular="{{false}}"
        indicator-dots="{{false}}"
        bindchange="handleSwiperChange"
      >
        <swiper-item wx:for="{{series}}" wx:key="code">
          <view class="card-wrapper">
            <series-card series="{{item}}" />
          </view>
        </swiper-item>
      </swiper>

      <!-- Page dots -->
      <view class="dots">
        <view
          wx:for="{{series}}"
          wx:key="code"
          class="dot {{index === activeIndex ? 'dot-active' : ''}}"
          data-index="{{index}}"
          bind:tap="scrollToIndex"
        ></view>
      </view>

      <!-- Subtitle -->
      <text class="subtitle">选择系列开始探索</text>
    </view>

    <!-- Loading -->
    <view class="loading" wx:if="{{loading}}">
      <text class="loading-text">加载中...</text>
    </view>
  </view>
</view>
