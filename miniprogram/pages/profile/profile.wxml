<scroll-view class="page" scroll-y>
  <view style="height: {{statusBarHeight}}px;"></view>
  <view class="title">我的</view>

  <!-- User avatar -->
  <view class="user-section">
    <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image
        class="avatar"
        src="{{avatarUrl}}"
        wx:if="{{avatarUrl}}"
        mode="aspectFill"
      />
      <view class="avatar-placeholder" wx:else>
        <text class="avatar-placeholder-text">+</text>
      </view>
    </button>
  </view>

  <!-- Menu -->
  <view class="menu-section">
    <view class="menu-item" bind:tap="handleWishlist" hover-class="menu-item-hover">
      <view class="menu-left">
        <view class="menu-icon wishlist-icon">
          <text>♡</text>
        </view>
        <text class="menu-label">心愿单</text>
      </view>
      <view class="menu-right">
        <text class="menu-count">{{wishlistCount}}</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view class="menu-divider"></view>

    <view class="menu-item" bind:tap="handlePurchased" hover-class="menu-item-hover">
      <view class="menu-left">
        <view class="menu-icon purchased-icon">
          <text>✓</text>
        </view>
        <text class="menu-label">已购买</text>
      </view>
      <view class="menu-right">
        <text class="menu-count">{{purchasedCount}}</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <view style="height: {{safeAreaBottom}}px;"></view>
</scroll-view>
