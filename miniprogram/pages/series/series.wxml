<view class="page">
  <header
    title="{{seriesTitle}}"
    showBack
    showFilter
    filterActive="{{filterOpen}}"
    bind:back="handleBack"
    bind:filtertap="handleFilterTap"
  />

  <view class="content">
    <!-- Search bar -->
    <view class="search-wrapper">
      <search-bar
        value="{{searchInput}}"
        placeholder="搜索 {{seriesTitle}} 型号..."
        bind:input="handleSearchInput"
        bind:clear="handleSearchInput"
      />
    </view>

    <!-- Category tabs -->
    <category-tabs
      activeTab="{{activeTab}}"
      regularCount="{{regularModels.length}}"
      limitedCount="{{limitedModels.length}}"
      bind:change="handleTabChange"
    />

    <!-- Limited sub-filter -->
    <limited-filter
      value="{{limitedSubFilter}}"
      models="{{limitedModels}}"
      visible="{{activeTab === 'limited'}}"
      bind:change="handleLimitedChange"
    />

    <!-- Sort bar -->
    <view class="sort-bar">
      <view class="result-count" wx:if="{{!loading}}">
        <text>共 {{resultCount}} 个模型</text>
      </view>
      <sort-selector
        options="{{sortOptions}}"
        value="{{sortValue}}"
        bind:change="handleSortChange"
      />
    </view>

    <!-- Filter panel -->
    <filter-panel
      open="{{filterOpen}}"
      releaseDateFrom="{{releaseDateFrom}}"
      releaseDateTo="{{releaseDateTo}}"
      numberFrom="{{numberFrom}}"
      numberTo="{{numberTo}}"
      bind:close="handleFilterClose"
      bind:filterchange="handleFilterChange"
      bind:reset="handleFilterReset"
    />

    <!-- Scrollable area -->
    <scroll-view
      class="scroll-area"
      scroll-y
      show-scrollbar="{{false}}"
      scroll-top="{{scrollTop}}"
      bindscroll="handleScroll"
    >

      <!-- Loading skeleton -->
      <view class="model-grid" wx:if="{{loading}}" style="padding: 0 24rpx;">
        <view class="skeleton-card skeleton-cell" wx:for="{{[1,2,3,4,5,6]}}" wx:key="*this">
          <view class="skeleton-image"></view>
          <view class="skeleton-info">
            <view class="skeleton-text" style="width: 40%;"></view>
            <view class="skeleton-text" style="width: 90%;"></view>
            <view class="skeleton-text" style="width: 55%;"></view>
          </view>
        </view>
      </view>

      <!-- Empty state -->
      <view class="empty-state" wx:elif="{{processedModels.length === 0}}">
        <text class="empty-text">未找到匹配的模型</text>
      </view>

      <!-- Model grid -->
      <view class="model-grid" wx:else style="padding: 0 24rpx; padding-bottom: calc(48rpx + {{safeAreaBottom}}px);">
        <model-card
          wx:for="{{processedModels}}"
          wx:key="id"
          model="{{item}}"
          isFavorite="{{favMap[item.id]}}"
          exchangeRate="{{exchangeRate}}"
          bind:select="handleModelSelect"
          bind:togglefavorite="handleToggleFavorite"
        />
      </view>
    </scroll-view>
  </view>

  <!-- Back to top button -->
  <view class="back-top" wx:if="{{showBackTop}}" bind:tap="handleBackTop" hover-class="back-top-hover" style="bottom: calc(32rpx + {{safeAreaBottom}}px);">
    <text class="back-top-icon">↑</text>
  </view>

  <!-- Model detail bottom sheet -->
  <model-detail
    model="{{selectedModel}}"
    open="{{detailOpen}}"
    isFavorite="{{selectedIsFav}}"
    isPurchased="{{selectedIsPurchased}}"
    exchangeRate="{{exchangeRate}}"
    bind:close="handleDetailClose"
    bind:togglefavorite="handleToggleFavorite"
    bind:purchase="handlePurchaseAction"
  />

  <purchase-form
    open="{{formOpen}}"
    modelId="{{formModelId}}"
    modelName="{{formModelName}}"
    priceCny="{{formPriceCny}}"
    purchaseDate="{{formPurchaseDate}}"
    channel="{{formChannel}}"
    note="{{formNote}}"
    bind:close="handleFormClose"
    bind:submit="handleFormSubmit"
  />
</view>
